{
  "name": "Spark Data Engineering",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "jupyter",
  "workspaceFolder": "/workspaces/Spark-Project",
  "remoteUser": "root",
  "forwardPorts": [4040, 7077, 8080, 8081, 8888],
  "portsAttributes": {
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "openBrowser"
    },
    "8080": {
      "label": "Spark Master UI",
      "onAutoForward": "notify"
    },
    "4040": {
      "label": "Spark Job UI",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "DATA_PATH": "/opt/spark-data"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.analysis.extraPaths": ["/opt/spark-app"]
      }
    }
  }
}
