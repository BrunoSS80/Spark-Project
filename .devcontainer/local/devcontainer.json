{
  "name": "Spark Data Engineering - Local",
  "dockerComposeFile": "../../docker-compose.yaml",
  "service": "jupyter",
  "workspaceFolder": "/opt/spark-project",
  "remoteUser": "root",
  "forwardPorts": [4040, 4041, 7077, 8080, 8081, 8888],
  "remoteEnv": {
    "DATA_PATH": "/opt/spark-data"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.pylance", "ms-toolsai.jupyter"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  }
}